_G.UseTeamColor = true

-- Active visual storage containers
local ESP_Holder = Instance.new("Folder")
ESP_Holder.Name = "Rayfield_Solid_ESP"
local ActiveTracers = {}

-- Secure parent insertion wrapper
local success = pcall(function() ESP_Holder.Parent = CoreGui end)
if not success then ESP_Holder.Parent = LocalPlayer:WaitForChild("PlayerGui") end

-- Aggressive Color Scanner to force team coloring and prevent white fallbacks
local function GetPlayerColor(player)
	if _G.UseTeamColor then
		if player.Team and player.Team:IsA("Team") then
			return player.Team.TeamColor.Color
		elseif player.TeamColor then
			return player.TeamColor.Color
		end
	end
	
	-- Fallback to Friend/Enemy colors if Team properties fail
	if player.Team == LocalPlayer.Team or player.TeamColor == LocalPlayer.TeamColor then
		return _G.FriendColor
	else
		return _G.EnemyColor
	end
end

-- Safely remove elements when player disconnects or dies
local function ClearPlayerVisuals(player)
	local pFolder = ESP_Holder:FindFirstChild(player.Name)
	if pFolder then pFolder:Destroy() end
	
	if ActiveTracers[player] then
		pcall(function()
			ActiveTracers[player].Visible = false
			ActiveTracers[player]:Remove()
		end)
		ActiveTracers[player] = nil
	end
end

-- Full cleanup function when toggled OFF
local function ClearAllESP()
	ESP_Holder:ClearAllChildren()
	for player, _ in pairs(ActiveTracers) do
		ClearPlayerVisuals(player)
	end
	table.clear(ActiveTracers)
end

-- Core layout drawing loop (Tied to frame ticks for 0% latency)
local function ProcessESP()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local char = player.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local head = char and char:FindFirstChild("Head")
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			
			if root and head and hum and hum.Health > 0 then
				local color = GetPlayerColor(player)
				
				-- Handle individual folder hierarchy creation
				local pFolder = ESP_Holder:FindFirstChild(player.Name)
				if not pFolder then
					pFolder = Instance.new("Folder", ESP_Holder)
					pFolder.Name = player.Name
				end
				
				-- ========================================================
				-- 1. SOLID FULL-BODY HIGHLIGHT (Matches your green image exactly)
				-- ========================================================
				local highlight = pFolder:FindFirstChild("SolidHighlight")
				if not highlight then
					highlight = Instance.new("Highlight")
					highlight.Name = "SolidHighlight"
					highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
					highlight.FillTransparency = 0 -- 0 = Solid color block through buildings
					highlight.OutlineTransparency = 0 -- Solid visible border line
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White hard border outline
					highlight.Adornee = char
					highlight.Parent = pFolder
				end
				highlight.FillColor = color
				
				-- ========================================================
				-- 2. DYNAMIC OVERHEAD TEAM-COLORED NAMETAG
				-- ========================================================
				local nametag = pFolder:FindFirstChild("OverheadName")
				if not nametag then
					nametag = Instance.new("BillboardGui")
					nametag.Name = "OverheadName"
					nametag.Size = UDim2.new(0, 200, 0, 40)
					nametag.AlwaysOnTop = true
					nametag.StudsOffset = Vector3.new(0, 2.5, 0) -- Places text box right above character bounds
					nametag.Adornee = head
					
					local textLabel = Instance.new("TextLabel", nametag)
					textLabel.Name = "Tag"
					textLabel.BackgroundTransparency = 1
					textLabel.Size = UDim2.new(1, 0, 1, 0)
					textLabel.TextSize = 14
					textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
					textLabel.TextStrokeTransparency = 0.2
					textLabel.Font = Enum.Font.SourceSansBold
					textLabel.Parent = nametag
					
					nametag.Parent = pFolder
				end
				
				-- Disable the standard default Roblox system text tags to prevent overlaps
				hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
				nametag.Tag.Text = player.DisplayName or player.Name
				nametag.Tag.TextColor3 = color -- Updates the text color frame-by-frame
				
				-- ========================================================
				-- 3. TEAM-COLORED LINE TRACERS (Forced Realtime Color updates)
				-- ========================================================
				local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
				
				if onScreen then
					if not ActiveTracers[player] then
						local line = Drawing.new("Line")
						line.Thickness = 1.5
						line.Transparency = 1
						ActiveTracers[player] = line
					end
					
					local tracer = ActiveTracers[player]
					tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) -- Screen Center Bottom Origin
					tracer.To = Vector2.new(screenPos.X, screenPos.Y)
					tracer.Color = color -- Forced update here ensures line updates dynamically
					tracer.Visible = true
				else
					if ActiveTracers[player] then ActiveTracers[player].Visible = false end
				end
			else
				ClearPlayerVisuals(player)
			end
		end
	end
end

