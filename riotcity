local function forceGetAndSyncWeapons()
    local backpack = localPlayer:WaitForChild("Backpack")
    local equippedCount = 0

    -- COMPLETE LOADOUT ARRAY (Updated with Grenade and RPG)
    local targetWeapons = {
        "AK47", "Shotgun", "Pistol", "SMG", "Uzi", "M4 Carbine", 
        "Tommy Gun", "Vector", "Shield", "Sig MCX", "Grenade", "RPG"
    }

    -- PHASE 1: DIRECT CACHE EXTRACTION AND HOTBAR INSERTION
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("Tool") and table.find(targetWeapons, obj.Name) then
            if not backpack:FindFirstChild(obj.Name) and not (localPlayer.Character and localPlayer.Character:FindFirstChild(obj.Name)) then
                pcall(function()
                    local weaponClone = obj:Clone()
                    weaponClone.Parent = backpack
                    equippedCount = equippedCount + 1
                end)
            end
        end
    end

    -- PHASE 2: GLOBAL DAMAGE SYNCHRONIZATION
    -- Bypasses local environment blocks by routing weapon tool states directly to your game's network tunnels
    task.spawn(function()
        local firingRemote = ReplicatedStorage:FindFirstChild("Hit") 
            or ReplicatedStorage:FindFirstChild("Damage") 
            or ReplicatedStorage:FindFirstChild("Shoot")
            or ReplicatedStorage:FindFirstChild("WeaponEvent")

        if firingRemote and firingRemote:IsA("RemoteEvent") then
            -- Establishes a framework connection tracking when cloned weapons hit a targeted player model
            RunService.Heartbeat:Connect(function()
                local character = localPlayer.Character
                if character then
                    local equippedTool = character:FindFirstChildOfClass("Tool")
                    if equippedTool and table.find(targetWeapons, equippedTool.Name) then
                        -- Pull weapon parameters when interacting with target hitboxes
                        for _, enemyPlayer in pairs(Players:GetPlayers()) do
                            if enemyPlayer ~= localPlayer and enemyPlayer.Character and enemyPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                local distance = (character.HumanoidRootPart.Position - enemyPlayer.Character.HumanoidRootPart.Position).Magnitude
                                -- Auto-calculates weapon range metrics for hit validation
                                if distance < 120 then
                                    pcall(function()
                                        -- Fire the game's official server remote with weapon parameters to force health reduction
                                        firingRemote:FireServer(enemyPlayer.Character.Humanoid, 25, equippedTool.Name)
                                    end)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)

    return equippedCount
end

