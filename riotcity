	updateSpeedLoop()
	
	-- Visually flip the checkmark/dot inside the Rayfield UI layout if it exists
	if walkspeedToggleElement and walkspeedToggleElement.Set then
		walkspeedToggleElement:Set(speedActive)
	end
end

