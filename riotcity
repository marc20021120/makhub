local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local speedActive = false
local currentSpeed = 100 -- Default speed number ready to type over
local speedConnection
local walkspeedToggleElement -- Reference to the toggle UI to update it visually

-- Core loop function that forces your walkspeed to update smoothly
local function updateSpeedLoop()
	if speedConnection then speedConnection:Disconnect() end

	if speedActive then
		speedConnection = RunService.RenderStepped:Connect(function()
			local char = LocalPlayer.Character
			if char then
				local hum = char:FindFirstChildOfClass("Humanoid")
				if hum and hum.WalkSpeed ~= currentSpeed then
					hum.WalkSpeed = currentSpeed
				end
			end
		end)
	else
		if speedConnection then speedConnection:Disconnect() end
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then 
				hum.WalkSpeed = 16 -- Safely return to normal Roblox speed
			end
		end
	end
end

-- Function to handle flipping the toggle when a key is pressed (PC Only)
local function handleToggleSwitch(newState)
	speedActive = newState
	updateSpeedLoop()
	
	-- Visually flip the checkmark/dot inside the Rayfield UI layout if it exists
	if walkspeedToggleElement and walkspeedToggleElement.Set then
		walkspeedToggleElement:Set(speedActive)
	end
end

-- Section container to keep the box and the switch locked in the same panel space
local WalkSpeedSection = MainTab:CreateSection("WalkSpeed Control")

-- 1. THE ADJUSTABLE TYPE BOX (Works on both PC and Android)
MainTab:CreateInput({
	Name = "Change WalkSpeed Number",
	PlaceholderText = "100",
	RemoveTextAfterFocusLost = false,
	Callback = function(text)
		local num = tonumber(text)
		if num then
			currentSpeed = num
			if speedActive then
				updateSpeedLoop()
			end
		else
			if text == "" then
				currentSpeed = 16
				if speedActive then updateSpeedLoop() end
			end
		end
	end
})

-- 2. THE UNIVERSAL SWITCH (Tap on Android, click on PC, or triggers via Keybind)
walkspeedToggleElement = MainTab:CreateToggle({
	Name = "Toggle Speed Switch (On / Off)",
	CurrentValue = false,
	Flag = "UniversalSpeedMasterFlag", 
	Callback = function(Value)
		speedActive = Value
		updateSpeedLoop()
	end
})

-- 3. THE PC KEYBIND DETECTOR (Completely hidden and bypassed on Android)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	-- Ignore keypresses if the player is busy typing numbers inside the menu or chatting
	if gameProcessed then return end
	
	-- PC check: Only triggers if the device uses keyboard inputs
	if input.UserInputType == Enum.UserInputType.Keyboard then
		-- UPDATED: Keybind changed to 'Q'
		if input.KeyCode == Enum.KeyCode.Q then 
			handleToggleSwitch(not speedActive) -- Reverse the current active state
		end
	end
end)

