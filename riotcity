local function getColor(teamName)
	if teamName == "Criminal" then
		return Color3.fromRGB(255,0,0)
	elseif teamName == "Cops" then
		return Color3.fromRGB(0,0,255)
	elseif teamName == "Inmate" then
		return Color3.fromRGB(255,165,0)
	else
		return Color3.fromRGB(255,255,255)
	end
end

----------------------------------------------------
-- ESP SYSTEM
----------------------------------------------------
local ESP_ENABLED = false
local ESP_CACHE = {}

local function clearESP()
	for _,objs in pairs(ESP_CACHE) do
		for _,v in pairs(objs) do
			if v then v:Destroy() end
		end
	end
	table.clear(ESP_CACHE)
end

local function createESP(plr)
	if plr == LocalPlayer then return end

	local function apply(char)
		if not ESP_ENABLED then return end

		local color = getColor(plr.Team and plr.Team.Name or "")

		-- FULL BODY COLOR
		for _,part in pairs(char:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Color = color
				part.Material = Enum.Material.Neon
			end
		end

		-- WALL HIGHLIGHT
		local highlight = Instance.new("Highlight")
		highlight.FillColor = color
		highlight.FillTransparency = 0.3
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Parent = char

		-- NAME
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end

		local billboard = Instance.new("BillboardGui", hrp)
		billboard.Size = UDim2.new(0,200,0,50)
		billboard.StudsOffset = Vector3.new(0,3,0)
		billboard.AlwaysOnTop = true

		local text = Instance.new("TextLabel", billboard)
		text.Size = UDim2.new(1,0,1,0)
		text.BackgroundTransparency = 1
		text.TextScaled = true
		text.TextColor3 = Color3.new(1,1,1)
		text.Text = plr.Name

		-- LINE ESP
		local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		local beam,a0,a1

		if myHRP then
			a0 = Instance.new("Attachment", myHRP)
			a1 = Instance.new("Attachment", hrp)

			beam = Instance.new("Beam")
			beam.Attachment0 = a0
			beam.Attachment1 = a1
			beam.Width0 = 0.2
			beam.Width1 = 0.2
			beam.Color = ColorSequence.new(color)
			beam.Parent = char
		end

		ESP_CACHE[plr] = {highlight, billboard, beam, a0, a1}
	end

	if plr.Character then apply(plr.Character) end
	plr.CharacterAdded:Connect(apply)
end

local function enableESP()
	for _,p in ipairs(Players:GetPlayers()) do
		createESP(p)
	end
end

