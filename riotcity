-- 🔔 NOTIFICATION
local function notify(title, text, time)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = time or 2
        })
    end)
end

-- SETTINGS
local arrestActive = false
local targetPlayerName = ""
local arrestConnection

-- 🔍 FIND TARGET
local function findTargetPlayer()
	if targetPlayerName == "" then return nil end
	for _, p in pairs(Players:GetPlayers()) do
		if string.find(p.Name:lower(), targetPlayerName:lower()) 
		or string.find(p.DisplayName:lower(), targetPlayerName:lower()) then
			if p ~= localPlayer then return p end
		end
	end
	return nil
end

-- 🔥 AUTO ARREST
local function runArrestCycle()
    arrestActive = not arrestActive
    
    if arrestActive then
        notify("⚙️ Auto Arrest", "Loop Activated!", 1.5)

        arrestConnection = RunService.Heartbeat:Connect(function()
            local targetUser = findTargetPlayer()
            local myChar = localPlayer.Character
            
            if targetUser and targetUser.Character and myChar then
                local myHrp = myChar:FindFirstChild("HumanoidRootPart")
                local enemyHrp = targetUser.Character:FindFirstChild("HumanoidRootPart")
                local enemyHum = targetUser.Character:FindFirstChildOfClass("Humanoid")
                local backpack = localPlayer:WaitForChild("Backpack")
                
                if myHrp and enemyHrp and enemyHum and enemyHum.Health > 0 then
                    pcall(function()
                        local cuffs = backpack:FindFirstChild("Handcuffs")
                            or backpack:FindFirstChild("Cuffs")
                            or myChar:FindFirstChild("Handcuffs")
                            or myChar:FindFirstChild("Cuffs")

                        if cuffs and cuffs.Parent == backpack then
                            cuffs.Parent = myChar
                        end

                        local targetVelocity = enemyHrp.AssemblyLinearVelocity
                        local compensation = targetVelocity.Magnitude > 0 and targetVelocity.Unit * 1.5 or Vector3.zero

                        myHrp.CFrame = CFrame.lookAt(
                            (enemyHrp.CFrame * CFrame.new(0,0,2.2)).Position + compensation,
                            enemyHrp.Position
                        )

                        myHrp.AssemblyLinearVelocity = targetVelocity

                        local camera = Workspace.CurrentCamera
                        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, enemyHrp.Position)

                        for _, obj in pairs(targetUser.Character:GetDescendants()) do
                            if obj:IsA("ProximityPrompt") and obj.Enabled then
                                fireproximityprompt(obj)
                            end
                        end

                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    end)
                end
            end
        end)

    else
        if arrestConnection then
            arrestConnection:Disconnect()
            arrestConnection = nil
        end

        pcall(function()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)

        notify("⚠️ Auto Arrest", "Loop Deactivated!", 2)
    end
end

