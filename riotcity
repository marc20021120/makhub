local flying = false
local flyConnection

local function toggleFly()
	local char = LocalPlayer.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChild("Humanoid")

	if not root or not hum then return end

	flying = not flying

	if flying then
		hum.PlatformStand = true

		local bv = Instance.new("BodyVelocity", root)
		bv.MaxForce = Vector3.new(9e9,9e9,9e9)

		local bg = Instance.new("BodyGyro", root)
		bg.MaxTorque = Vector3.new(9e9,9e9,9e9)

		flyConnection = RunService.RenderStepped:Connect(function()
			local cam = workspace.CurrentCamera
			local move = Vector3.zero

			-- KEYBOARD
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) end

			-- CONTROLLER
			for _,input in pairs(UserInputService:GetGamepadState(Enum.UserInputType.Gamepad1)) do
				if input.KeyCode == Enum.KeyCode.Thumbstick1 then
					move += cam.CFrame.LookVector * -input.Position.Y
					move += cam.CFrame.RightVector * input.Position.X
				end
			end

			bv.Velocity = move.Magnitude > 0 and move.Unit * 80 or Vector3.zero
			bg.CFrame = cam.CFrame
		end)

	else
		hum.PlatformStand = false
		if flyConnection then flyConnection:Disconnect() end

		for _,v in pairs(root:GetChildren()) do
			if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then
				v:Destroy()
			end
		end
	end
end

MainTab:CreateButton({
	Name = "Toggle Fly",
	Callback = toggleFly
})

