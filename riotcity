local Workspace = game:GetService("Workspace")

local laserActive = false
local originalLaserData = {} -- Stores real laser values for perfect restoration
local dynamicConnection -- Safely watches for new lasers streaming in

-- Fast verification function to check if an object acts as a laser
local function CleanLaserObject(obj)
	if not obj:IsA("BasePart") then return end
	
	local name = string.lower(obj.Name)
	local color = obj.Color
	local isGlowingBeam = obj.Material == Enum.Material.Neon and (color.R > 0.6 and color.B < 0.4)
	
	if isGlowingBeam or name:find("laser") or name:find("beam") or obj.Name == "Bar" or obj.Name == "Sec" then
		pcall(function()
			-- Cache original structural properties before changing them
			if not originalLaserData[obj] then
				originalLaserData[obj] = {
					Size = obj.Size,
					Transparency = obj.Transparency,
					CanCollide = obj.CanCollide
				}
			end
			
			-- Strip physics properties completely
			obj.CanCollide = false
			obj.Transparency = 1 
			obj.Size = Vector3.new(0, 0, 0) 
			
			-- Destroy damage touch listener loop instantly
			local transmitter = obj:FindFirstChildOfClass("TouchTransmitter")
			if transmitter then transmitter:Destroy() end
		end)
	end
end

local function toggleLaserSystem()
	laserActive = not laserActive
	
	-- Display a responsive notification pop-up matching your Rayfield style
	if Rayfield and Rayfield.Notify then
		Rayfield:Notify({
			Title = "Laser System",
			Content = laserActive and "Lasers Removed (SAFE)" or "Lasers Restored (LETHAL)",
			Duration = 2
		})
	end
	
	if laserActive then
		-- ========================================================
		-- ACTIVATED STATE: ONE-TIME SWEEP (ZERO LAG)
		-- ========================================================
		-- Runs exactly once instead of 60 times a second, completely eliminating lag
		for _, obj in pairs(Workspace:GetDescendants()) do
			CleanLaserObject(obj)
		end
		
		-- Watch for newly spawned lasers or map chunks streaming in
		dynamicConnection = Workspace.DescendantAdded:Connect(function(descendant)
			if laserActive then
				CleanLaserObject(descendant)
			end
		end)
	else
		-- ========================================================
		-- DEACTIVATED STATE: RESTORE ORIGINAL MAP STATE
		-- ========================================================
		if dynamicConnection then 
			dynamicConnection:Disconnect() 
			dynamicConnection = nil
		end
		
		for obj, data in pairs(originalLaserData) do
			pcall(function()
				if obj and obj.Parent then
					-- Force snap properties back to original world positions
					obj.Size = data.Size
					obj.Transparency = data.Transparency
					obj.CanCollide = data.CanCollide
					
					-- Re-inject a functional TouchTransmitter to reactivate player damage
					local dummyPart = Instance.new("Part")
					local newTransmitter = Instance.new("TouchTransmitter", dummyPart)
					newTransmitter.Parent = obj
					dummyPart:Destroy()
				end
			end)
		end
		-- Empty the restoration table buffer
		table.clear(originalLaserData)
	end
end

