-- SETTINGS
local shopPos = Vector3.new(-163.0, -32.1, -1265.8)
local busy = false

-- 🔥 CLICK ALL EQUIP BUTTONS (MAIN FIX)
local function equipAllFromUI()
    local playerGui = localPlayer:WaitForChild("PlayerGui")
    local equipped = 0

    for _, obj in pairs(playerGui:GetDescendants()) do
        if obj:IsA("TextButton") then
            if string.lower(obj.Text) == "equip" then
                pcall(function()
                    -- simulate button click
                    for _, con in pairs(getconnections(obj.MouseButton1Click)) do
                        con:Fire()
                    end
                    equipped += 1
                    task.wait(0.1)
                end)
            end
        end
    end

    return equipped
end

-- MAIN FUNCTION
local function executeWarp()
    if busy then return end

    local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")

    if not hrp then
        notify("❌ Error", "Character not loaded", 3)
        return
    end

    busy = true
    notify("⚙️ Weapons", "Opening shop...", 1.5)

    local oldCFrame = hrp.CFrame

    -- TELEPORT TO SHOP
    hrp.CFrame = CFrame.new(shopPos)
    task.wait(0.6)

    -- 🔥 EQUIP ALL FROM UI
    local equipped = equipAllFromUI()

    task.wait(0.3)

    -- RETURN
    hrp.CFrame = oldCFrame
    busy = false

    -- 🔔 RESULT
    if equipped > 0 then
        notify("🔔 Equipped", "Equipped "..equipped.." weapons", 3)
    else
        notify("⚠️ Failed", "No Equip buttons found", 3)
    end
end

