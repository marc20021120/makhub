_G.MakHubRayfield = {}

function _G.MakHubRayfield:CreateWindow(config)
	local WindowAPI = {}
	function WindowAPI:CreateTab(tabName, icon)
		SettingsPage.Visible = false
		local Page = Instance.new("ScrollingFrame")
		Page.Size = UDim2.new(1, 0, 1, 0)
		Page.BackgroundTransparency = 1
		Page.CanvasSize = UDim2.new(0, 0, 0, 0)
		Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
		Page.ScrollBarThickness = 3
		Page.ScrollBarImageColor3 = Color3.fromRGB(0, 200, 210)
		Page.Visible = FirstTab
		Page.Parent = ContentFrame

		local PageLayout = Instance.new("UIListLayout")
		PageLayout.Padding = UDim.new(0, 6)
		PageLayout.Parent = Page

		local TabBtn = Instance.new("TextButton")
		TabBtn.Size = UDim2.new(0, 130, 0, 36)
		TabBtn.BackgroundTransparency = 1
		TabBtn.Text = tabName
		TabBtn.TextSize = 15
		TabBtn.Font = Enum.Font.SourceSansSemibold
		TabBtn.TextColor3 = FirstTab and Color3.fromRGB(0, 240, 245) or Color3.fromRGB(140, 160, 180)
		TabBtn.TextXAlignment = Enum.TextXAlignment.Left
		TabBtn.Parent = Sidebar
		
		local TabPadding = Instance.new("UIPadding")
		TabPadding.PaddingLeft = UDim.new(0, 12)
		TabPadding.Parent = TabBtn
		
		table.insert(Pages, Page)
		table.insert(TabButtons, TabBtn)

		TabBtn.MouseButton1Click:Connect(function()
			SettingsPage.Visible = false
			for _, p in ipairs(Pages) do p.Visible = false end
			for _, b in ipairs(TabButtons) do b.TextColor3 = Color3.fromRGB(140, 160, 180) end
			Page.Visible = true
			TabBtn.TextColor3 = Color3.fromRGB(0, 240, 245)
		end)

		if FirstTab then FirstTab = false end
		local TabAPI = {}
		
		function TabAPI:CreateButton(options)
			local row = Instance.new("Frame")
			row.Size = UDim2.new(1, -10, 0, 48)
			row.BackgroundColor3 = Color3.fromRGB(16, 36, 56)
			row.BackgroundTransparency = 0.50
			row.Parent = Page
			Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
			table.insert(ThemeElements.ElementBg, row)

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -24, 1, -12)
			btn.Position = UDim2.new(0, 12, 0, 6)
			btn.BackgroundColor3 = Color3.fromRGB(24, 54, 84)
			btn.BackgroundTransparency = 0.35
			btn.Text = options.Name
			btn.TextColor3 = Color3.fromRGB(0, 240, 245)
			btn.TextSize = 15
			btn.Font = Enum.Font.SourceSansBold
			btn.Parent = row
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
			table.insert(ThemeElements.Accent, btn)

			btn.MouseButton1Click:Connect(options.Callback)
		end

		function TabAPI:CreateToggle(options)
			local row = Instance.new("Frame")
			row.Size = UDim2.new(1, -10, 0, 48)
			row.BackgroundColor3 = Color3.fromRGB(16, 36, 56)
			row.BackgroundTransparency = 0.50
			row.Parent = Page
			Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
			table.insert(ThemeElements.ElementBg, row)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0, 250, 1, 0)
			label.Position = UDim2.new(0, 12, 0, 0)
			label.BackgroundTransparency = 1
			label.Text = options.Name
			label.TextColor3 = Color3.fromRGB(0, 240, 245)
			label.TextSize = 15
			label.Font = Enum.Font.SourceSansSemibold
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = row

			local toggleBg = Instance.new("TextButton")
			toggleBg.Size = UDim2.new(0, 42, 0, 24)
			toggleBg.Position = UDim2.new(1, -55, 0.5, -12)
			toggleBg.BackgroundColor3 = options.CurrentValue and Color3.fromRGB(0, 240, 245) or Color3.fromRGB(24, 54, 84)
			toggleBg.BackgroundTransparency = 0.3
			toggleBg.Text = ""
			toggleBg.Parent = row
			Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)

			local toggleBall = Instance.new("Frame")
			toggleBall.Size = UDim2.new(0, 18, 0, 18)
			toggleBall.Position = options.CurrentValue and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
			toggleBall.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
			toggleBall.Parent = toggleBg
			Instance.new("UICorner", toggleBall).CornerRadius = UDim.new(1, 0)

			local active = options.CurrentValue
			toggleBg.MouseButton1Click:Connect(function()
				active = not active
				local targetPos = active and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
				local targetColor = active and Color3.fromRGB(0, 240, 245) or Color3.fromRGB(24, 54, 84)
				TweenService:Create(toggleBall, TweenInfo.new(0.15), {Position = targetPos}):Play()
				TweenService:Create(toggleBg, TweenInfo.new(0.15), {BackgroundColor3 = targetColor}):Play()
				options.Callback(active)
			end)
		end

		function TabAPI:CreateSlider(options)
			local row = Instance.new("Frame")
			row.Size = UDim2.new(1, -10, 0, 48)
			row.BackgroundColor3 = Color3.fromRGB(16, 36, 56)
			row.BackgroundTransparency = 0.50
			row.Parent = Page
			Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
			table.insert(ThemeElements.ElementBg, row)

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(0, 160, 1, 0)
			label.Position = UDim2.new(0, 12, 0, 0)
			label.BackgroundTransparency = 1
			label.Text = options.Name
			label.TextColor3 = Color3.fromRGB(0, 240, 245)
			label.TextSize = 15
			label.Font = Enum.Font.SourceSansSemibold
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = row

			local sliderTrack = Instance.new("Frame")
			sliderTrack.Size = UDim2.new(0, 180, 0, 4)
			sliderTrack.Position = UDim2.new(1, -250, 0.5, -2)
			sliderTrack.BackgroundColor3 = Color3.fromRGB(24, 54, 84)
			sliderTrack.Parent = row

			local sliderFill = Instance.new("Frame")
			sliderFill.Size = UDim2.new((options.CurrentValue - options.Min) / (options.Max - options.Min), 0, 1, 0)
			sliderFill.BackgroundColor3 = Color3.fromRGB(0, 240, 245)
			sliderFill.Parent = sliderTrack

			local sliderBtn = Instance.new("ImageButton")
			sliderBtn.Size = UDim2.new(0, 14, 0, 14)
			sliderBtn.Position = UDim2.new((options.CurrentValue - options.Min) / (options.Max - options.Min), -7, 0.5, -7)
			sliderBtn.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
			sliderBtn.Parent = sliderTrack
			Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(1, 0)

			local valueLabel = Instance.new("TextLabel")
			valueLabel.Size = UDim2.new(0, 45, 1, 0)
			valueLabel.Position = UDim2.new(1, -50, 0, 0)
			valueLabel.BackgroundTransparency = 1
			valueLabel.Text = tostring(options.CurrentValue)
			valueLabel.TextColor3 = Color3.fromRGB(180, 200, 210)
			valueLabel.TextSize = 14
			valueLabel.Font = Enum.Font.SourceSans
			valueLabel.TextXAlignment = Enum.TextXAlignment.Right
			valueLabel.Parent = row

			local dragging = false
			local function updateSlider(input)
				local percentage = math.clamp((input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
				sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
				sliderBtn.Position = UDim2.new(percentage, -7, 0.5, -7)
				local val = math.round(options.Min + (percentage * (options.Max - options.Min)))
				valueLabel.Text = tostring(val)
				options.Callback(val)
			end

			sliderBtn.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end
			end)
		end

		return TabAPI
	end
	return WindowAPI
end

